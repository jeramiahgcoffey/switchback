# Copy to .env.local and fill in. .env.local is gitignored; never commit secrets.

# --- MongoDB Atlas ---
# Atlas -> Connect -> Drivers gives this SRV string. Put the DB user's password in.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=switchback"
# Database the app reads/writes (Better Auth + app collections live here).
MONGODB_DB="switchback"

# --- Better Auth ---
# Min 32 chars, high entropy. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
# Base URL of this app. Dev: http://localhost:3000  Prod: https://switchback.jeramiahcoffey.com
BETTER_AUTH_URL="http://localhost:3000"

# --- GitHub OAuth (optional) ---
# Register at https://github.com/settings/developers (New OAuth App).
# Authorization callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
# Leave both blank to disable the GitHub sign-in button.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
